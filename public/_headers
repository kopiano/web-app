/*
  X-Content-Type-Options: nosniff

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Keep immutable caching limited to fingerprinted media and font files.
# Applying it to every asset can permanently cache an HTML fallback for a
# missing JavaScript file.
/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable

/assets/*.png
  Cache-Control: public, max-age=31536000, immutable

/assets/*.ttf
  Cache-Control: public, max-age=31536000, immutable

/assets/*.js
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*.css
  Cache-Control: no-cache, no-store, must-revalidate
